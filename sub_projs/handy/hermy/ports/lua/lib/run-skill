#!/usr/bin/env lua
-- run-skill <name>（Lua 版）— stdin=參數 JSON → exec ../skills/<name>/run → stdout=結果（截斷保護）。
-- 「手」的最小單元：shell-out 呼叫一個 folder-as-callable 技能。
local function q(s) return "'"..tostring(s):gsub("'", "'\\''").."'" end
local function exists(p) local f = io.open(p); if f then f:close(); return true end; return false end
local function slurp(p) local f = io.open(p); if not f then return "" end; local s = f:read("*a"); f:close(); return s or "" end
local function tmp(s) local t = os.tmpname(); local f = io.open(t, "w"); f:write(s or ""); f:close(); return t end

local HERE = arg[0]:match("^(.*)/[^/]*$") or "."
local D = os.getenv("HERMY_SKILLS_DIR"); if not D or D == "" then D = HERE.."/../skills" end
local name = arg[1] or ""
local run = D.."/"..name.."/run"
if name == "" or not exists(run) then print("[找不到技能 "..name.."]"); os.exit(0) end

local af = tmp(io.read("*a") or "")
local of, ef, cf = os.tmpname(), os.tmpname(), os.tmpname()
os.execute("timeout 300 "..q(run).." < "..af.." > "..of.." 2> "..ef.."; echo $? > "..cf)
local out = slurp(of):gsub("%s+$", "")
local code = tonumber((slurp(cf):gsub("%s", ""))) or 0
if code ~= 0 then
  local err = slurp(ef):gsub("%s+$", "")
  out = "[退出碼 "..code.."] "..(err ~= "" and err or out)
end
for _, p in ipairs({af, of, ef, cf}) do os.remove(p) end
print(out ~= "" and out:sub(1, 8000) or "（技能無輸出）")
