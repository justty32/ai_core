#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# shell 技能：收 {"command": "..."} 於 stdin，用 sh -c 執行，印 stdout（含 stderr 尾註）。
import json, subprocess, sys

args = json.loads(sys.stdin.read() or "{}")
cmd = args.get("command", "")
if not cmd:
    print("[shell] 缺 command 參數"); sys.exit(0)
p = subprocess.run(["sh", "-c", cmd], capture_output=True, text=True, timeout=120)
out = p.stdout
if p.stderr.strip():
    out += ("\n[stderr] " + p.stderr.strip())
if p.returncode != 0:
    out = f"[退出碼 {p.returncode}]\n" + out
print(out.strip() or "（無輸出）")
