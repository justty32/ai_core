#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# ds-chat — 一次 DeepSeek 呼叫：stdin={"messages":[...],"tools":[...]} → stdout=回應 message JSON。
# 「腦」的最小單元：一次請求一次呼叫，無狀態；messages 由編排器自管。
import json, os, sys, urllib.request, urllib.error

KEY = os.environ.get("DEEPSEEK_API_KEY")
if not KEY:
    print("[ds-chat] 未設 DEEPSEEK_API_KEY", file=sys.stderr); sys.exit(2)
MODEL = os.environ.get("HERMY_MODEL") or "deepseek-chat"
ENDPOINT = os.environ.get("HERMY_ENDPOINT") or "https://api.deepseek.com/v1/chat/completions"

req = json.loads(sys.stdin.read() or "{}")
body = {"model": MODEL, "messages": req.get("messages", [])}
if req.get("tools"):
    body["tools"] = req["tools"]; body["tool_choice"] = "auto"
r = urllib.request.Request(ENDPOINT, method="POST",
    data=json.dumps(body, ensure_ascii=False).encode("utf-8"),
    headers={"Content-Type": "application/json", "Authorization": f"Bearer {KEY}"})
try:
    with urllib.request.urlopen(r, timeout=120) as resp:
        data = json.loads(resp.read().decode("utf-8"))
except urllib.error.HTTPError as e:
    print(f"[ds-chat] HTTP {e.code}: {e.read().decode('utf-8', 'replace')[:500]}", file=sys.stderr); sys.exit(1)
except Exception as e:
    print(f"[ds-chat] 請求失敗：{e}", file=sys.stderr); sys.exit(1)
print(json.dumps(data["choices"][0]["message"], ensure_ascii=False))
