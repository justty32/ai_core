#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# run-skill <name> — stdin=參數 JSON → exec ../skills/<name>/run → stdout=結果（截斷保護）。
# 「手」的最小單元：shell-out 呼叫一個 folder-as-callable 技能。
import os, subprocess, sys
from pathlib import Path

D = Path(os.environ.get("HERMY_SKILLS_DIR") or (Path(__file__).resolve().parent.parent / "skills"))
name = sys.argv[1] if len(sys.argv) > 1 else ""
run = D / name / "run"
if not name or not run.exists():
    print(f"[找不到技能 {name}]"); sys.exit(0)
args = sys.stdin.read()
try:
    p = subprocess.run([str(run)], input=args, capture_output=True, text=True, timeout=300)
    out = p.stdout.strip()
    if p.returncode != 0:
        out = f"[退出碼 {p.returncode}] " + (p.stderr.strip() or out)
    print(out[:8000] if out else "（技能無輸出）")
except Exception as e:
    print(f"[技能執行失敗] {e}")
