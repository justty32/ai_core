#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# mem-append — stdin=一筆 JSON record → 加 ts → append 到 ../memory/log.ndjson。
# 「記憶」的最小單元：對話後同步（append-log）。
import json, os, sys
from datetime import datetime, timezone
from pathlib import Path

M = Path(os.environ.get("HERMY_MEMORY_DIR") or (Path(__file__).resolve().parent.parent / "memory"))
M.mkdir(parents=True, exist_ok=True)
raw = sys.stdin.read()
try:
    rec = json.loads(raw or "{}")
except Exception:
    rec = {"raw": raw}
rec["ts"] = datetime.now(timezone.utc).isoformat()
with (M / "log.ndjson").open("a", encoding="utf-8") as f:
    f.write(json.dumps(rec, ensure_ascii=False) + "\n")
