#!/usr/bin/env sh
# _exec — folder-as-callable 的入口薄殼：把呼叫原樣轉給同層的 Fennel 本體 _exec.fnl。
#
# 為什麼分兩檔：本體用 .fnl 副檔名編輯器才給 Fennel 語法高亮（沒高亮讀起來很痛）；
# 但 folder-as-callable 慣例要一個固定名 `_exec` 當入口，故留這支 shell shim 當門面，
# 真正邏輯全在 _exec.fnl。用法與 _exec.fnl 完全相同：_exec <endpoint> [llm 參數...]。
#
# readlink -f 解 symlink（上 PATH 時 $0 是 symlink），才找得到同層的 _exec.fnl。
self=$(readlink -f -- "$0")
here=$(CDPATH= cd -- "$(dirname -- "$self")" && pwd)
exec "$here/_exec.fnl" "$@"
