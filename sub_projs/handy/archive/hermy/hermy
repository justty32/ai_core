#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# hermy — 編排器：把 lib/* 小原語用 CLI 串起來跑 agent 迴圈（每檔 <50 行、可單獨呼叫）。
# 串連：lib/skills-json（發現）→ lib/ds-chat（一次呼叫）→ lib/run-skill（執行）→ lib/mem-append（記憶）。
# messages 由本檔自管；本質映射與用法見 README.md。用法：hermy <任務...> 或 echo ... | hermy
import json, os, subprocess, sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
LIB = HERE / "lib"
SYSTEM = (HERE / "prompt" / "system.md").read_text(encoding="utf-8").strip()
MAX = int(os.environ.get("HERMY_MAX_STEPS") or "12")

def call(tool, *args, stdin=""):
    p = subprocess.run([str(LIB / tool), *args], input=stdin, capture_output=True, text=True)
    if p.stderr.strip(): print(p.stderr.strip(), file=sys.stderr)
    if p.returncode != 0: sys.exit(p.returncode)
    return p.stdout

def mem(rec): call("mem-append", stdin=json.dumps(rec, ensure_ascii=False))

def main():
    task = " ".join(sys.argv[1:]).strip()
    if not task and not sys.stdin.isatty(): task = sys.stdin.read().strip()
    if not task: print("用法：hermy <任務...>   或   echo ... | hermy", file=sys.stderr); sys.exit(2)
    tools = json.loads(call("skills-json") or "[]")
    print(f"[hermy] 載入 {len(tools)} 個技能", file=sys.stderr)
    messages = [{"role": "system", "content": SYSTEM}, {"role": "user", "content": task}]
    mem({"role": "user", "content": task})
    for _ in range(MAX):
        msg = json.loads(call("ds-chat", stdin=json.dumps({"messages": messages, "tools": tools}, ensure_ascii=False)))
        messages.append(msg)
        calls = msg.get("tool_calls") or []
        if not calls:
            print(msg.get("content") or ""); mem({"role": "assistant", "content": msg.get("content")}); return
        for c in calls:
            fn, args = c["function"]["name"], c["function"].get("arguments") or "{}"
            print(f"[hermy] → 技能 {fn} {args}", file=sys.stderr)
            result = call("run-skill", fn, stdin=args).strip()
            if fn == "create_skill": tools = json.loads(call("skills-json") or "[]")
            messages.append({"role": "tool", "tool_call_id": c["id"], "content": result})
            mem({"role": "tool", "name": fn, "result": result[:2000]})
    print(f"[hermy] 到達步數上限 {MAX}", file=sys.stderr)

if __name__ == "__main__":
    main()
