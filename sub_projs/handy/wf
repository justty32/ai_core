#!/usr/bin/env fennel
;; wf — 兩層任務派發器：用 llme（DeepSeek）當路由腦，判斷任務「要不要動手」，
;;      只需腦的走 llme、要動手的走 claude code（headless agent）。
;;
;; workflows repo 那套是「給人開的 Claude Code 照著跑的 markdown 提示」；wf 是它的
;; **可執行復刻**，且**基於 handy 自己的 stack（llme）**——llme 既是路由器，也是簡單
;; 任務的執行者；只有真需要「手」（讀寫檔、跑指令、跨多檔改）才升級到 claude。
;;
;;   wf 幫我把 foo.py 的錯誤處理補上         auto：分類→多半判 AGENT→claude 動手
;;   wf 用繁中解釋什麼是 mmap                auto：判 BRAIN→llme 直接答
;;   cat foo.py | wf 幫我改、加型別註記        pipe＝附給任務的上下文
;;   wf -b <任務>                            強制 BRAIN（走 llme，跳過分類）
;;   wf -a <任務>                            強制 AGENT（走 claude，跳過分類）
;;   wf -i <任務>                            非同步投遞 inbox（轉 `mail send`，不當場等）
;;   wf < TASK.md                            無參數＝整個 stdin 當任務
;;
;; 三模式：-b 只需腦(llme) / -a 當場動手(claude) / -i 非同步交接(inbox，由 `mail run` 之後 drain)。
;; auto（不給旗標）在 brain/agent 之間分類，順序＝**啟發式關鍵詞（免 LLM）＞ LLM 分類**：
;;   清楚的任務（含「改/修/重構/跑」或「解釋/翻譯/什麼是」等詞）用固定腳本當場判掉、0 個 LLM
;;   call；只有模稜兩可（兩類詞都中或都沒中）才 fallback 花一個 llme call 分類。
;;   ——「能固定成腳本的判斷就別呼叫 LLM」的部分求值原則。「太複雜、不想當場等」用 -i 投 inbox。
;;
;; 環境變數（handy 慣例，改行為不改碼）：
;;   WF_ENDPOINT    llme 的 endpoint（預設 "deepseek"；BRAIN 執行與路由分類都用它）
;;   WF_LLME        覆寫 llme 執行檔（預設 "llme"；測試設 echo 可看轉出的命令）
;;   WF_CLAUDE      覆寫 claude 執行檔（預設 "claude"；測試設 echo）
;;   WF_PERMISSION  claude --permission-mode（預設 "acceptEdits"：自動接受改檔、其餘
;;                  危險操作仍受管；要全自主設 "bypassPermissions"，自負風險）
;;   WF_MODEL       claude --model（預設不帶＝繼承 claude 預設）
;;   WF_EFFORT      claude --effort（選填，如 high）
;;   WF_SYSTEM      追加 system 指示（預設要 agent/llme 用繁中溝通；設空字串關掉）

(fn getenv-nonempty [k]
  (let [v (os.getenv k)]
    (if (and v (not= v "")) v nil)))

(fn shquote [s] (.. "'" (s:gsub "'" "'\\''") "'"))
(fn trim [s] (or (s:match "^%s*(.-)%s*$") s))
(fn upper [s] (s:upper))

(fn dirname [path] (or (path:match "(.*)/[^/]*$") "."))
(fn abspath [path] (if (path:match "^/") path (.. (or (os.getenv "PWD") ".") "/" path)))
(fn script-dir [] (dirname (abspath (. arg 0))))

;; stdin 被 pipe / 重導才讀（test -t 0 不讀位元組、安全），避免互動卡等 EOF。
(fn stdin-piped? []
  (not (os.execute "test -t 0")))

(fn capture [cmd]
  (with-open [p (io.popen cmd)]
    (p:read "*a")))

;; ── 解析前置旗標（-b/--brain、-a/--agent、-- 停止）＋收任務詞 ──────────
(var force nil)   ; nil＝auto；"brain"／"agent"
(var i 1)
(var stop false)
(local words [])
(while (<= i (length arg))
  (let [a (. arg i)]
    (if stop
        (table.insert words a)
        (or (= a "-b") (= a "--brain")) (set force "brain")
        (or (= a "-a") (= a "--agent")) (set force "agent")
        (or (= a "-i") (= a "--inbox")) (set force "inbox")
        (= a "--") (set stop true)
        (or (= a "-h") (= a "--help"))
          (do (io.stderr:write "用法：wf [-b|-a] <任務...>；或 … | wf <任務>；或 wf < TASK.md\n"
                               "  -b 強制走 llme（只需腦）；-a 強制走 claude（要動手）；預設 auto 分類。\n")
              (os.exit 0))
        (table.insert words a)))
  (set i (+ i 1)))

;; ── 取輸入：argv＝任務指令；pipe＝上下文 ─────────────────────────
(local task (table.concat words " "))
(local piped (stdin-piped?))
(local ctx (if piped (trim (io.read "*a")) nil))
(local has-ctx (and ctx (< 0 (length ctx))))

(local prompt
  (if (< 0 (length task))
      (if has-ctx (.. task "\n\n--- 以下為透過管線傳入的上下文 ---\n" ctx) task)
      (if has-ctx ctx nil)))

(when (= prompt nil)
  (io.stderr:write
    "用法：wf [-b|-a] <任務...>            例：wf 幫我把 foo.py 的錯誤處理補上\n"
    "      cat foo.py | wf 幫我改          （pipe 當上下文附給任務）\n"
    "      wf < TASK.md                    （無參數＝整個 stdin 當任務）\n"
    "  -b 強制 llme（只需腦）／-a 強制 claude（要動手）；預設 auto 由 llme 分類。\n")
  (os.exit 2))

;; ── 啟發式路由：能用固定腳本判的就別花 LLM call（部分求值／減少呼叫）─────
;; 高精度關鍵詞（寧可漏判交給 LLM，也別誤判）；英文小寫、中文原樣皆對 lower 後的字串比對。
(local AGENT-PATS   ; 需要動手／落檔／執行
  ["改" "修改" "修復" "修正" "修好" "改好" "弄好" "搞定" "重構" "重寫" "改寫" "改成"
   "新增" "加上" "增加" "刪除" "刪掉" "移除" "替換" "取代" "實作" "實現" "執行" "跑一下"
   "編譯" "打包" "測試" "部署" "安裝" "建立" "建置" "初始化" "清理" "重命名" "格式化"
   "refactor" "fix" "edit" "implement" "rename" "deploy" "install" "commit" "build"])
(local BRAIN-PATS   ; 只需生成／回答（不落檔）
  ["解釋" "說明" "什麼是" "甚麼是" "何謂" "為什麼" "為何" "翻譯" "總結" "摘要" "概述"
   "定義" "舉例" "比較" "介紹" "explain" "translate" "summarize" "summarise" "define" "what is" "why"])

(fn any-match? [low pats]
  (var hit false)
  (each [_ p (ipairs pats) &until hit]
    (when (string.find low p 1 true) (set hit true)))
  hit)

;; 回 "agent" / "brain" / nil（模稜兩可→交給 LLM）
(fn heuristic-route [text]
  (let [low (text:lower)
        a (any-match? low AGENT-PATS)
        b (any-match? low BRAIN-PATS)]
    (if (and a (not b)) "agent"
        (and b (not a)) "brain"
        nil)))

(local endpoint (or (getenv-nonempty "WF_ENDPOINT") "deepseek"))
(local llme (or (getenv-nonempty "WF_LLME") "llme"))
(local claude (or (getenv-nonempty "WF_CLAUDE") "claude"))
(local system (let [s (os.getenv "WF_SYSTEM")]
                (if (= s nil) "與使用者溝通時用繁體中文。" s)))

;; ── 路由：auto 時用 llme（DeepSeek）判 AGENT/BRAIN ───────────────────
(local CLASSIFY-SYS
  (.. "你是任務路由器。判斷使用者的任務**是否需要實際動手**（讀寫檔案、執行指令、"
      "跨多檔修改、跑測試等 agent 能力）。需要動手→回 AGENT；只需生成文字／回答／"
      "翻譯／摘要／寫一段內容（不落檔）→回 BRAIN。只回一個詞：AGENT 或 BRAIN。"))

(fn classify [text]
  ;; 回 "agent" 或 "brain"；不清楚/失敗 → "agent"（偏向能完成動手任務，較安全）
  (let [cmd (table.concat
              [(shquote llme) (shquote endpoint)
               "--temperature" "0" "--max-tokens" "16"
               "--system" (shquote CLASSIFY-SYS)
               "--" (shquote text)] " ")
        out (upper (trim (or (capture cmd) "")))]
    (if (out:match "BRAIN") "brain"
        (out:match "AGENT") "agent"
        "agent")))

;; 決策順序：強制旗標 ＞ 啟發式（免 LLM）＞ LLM 分類（只有前兩者沒定案才呼叫）
(local heur (if force nil (heuristic-route prompt)))
(local route (or force heur (classify prompt)))
(local how (if force "強制" heur "啟發式・免 LLM" (.. "llme 分類，endpoint=" endpoint)))
(io.stderr:write (.. "[wf] 路由：" route "（" how "）\n"))

;; inbox 模式：非同步投遞，轉呼同層 mail send（task 與 ctx 分開傳，slug 才乾淨），
;; 不當場等（之後 `mail run` drain）。
(when (= route "inbox")
  (let [mail (.. (script-dir) "/mail")
        send-task (if (< 0 (length task)) task (or ctx ""))
        base (table.concat [(shquote mail) "send" (shquote send-task)] " ")
        ;; 有 argv task 且另有 pipe 上下文 → 把 ctx 經 stdin 餵給 mail（它會分欄記）
        cmd (if (and has-ctx (< 0 (length task)))
                (.. "printf %s " (shquote ctx) " | " base)
                base)
        (_ _ code) (os.execute cmd)]
    (os.exit (or code 0))))

;; ── 執行（brain / agent 當場跑）──────────────────────────────────────
(local parts
  (if (= route "brain")
      ;; 只需腦 → llme（DeepSeek）直接答，串流吐出
      (let [p [(shquote llme) (shquote endpoint) "--stream"]]
        (when (< 0 (length system))
          (table.insert p "--system") (table.insert p (shquote system)))
        (table.insert p "--") (table.insert p (shquote prompt))
        p)
      ;; 要動手 → claude -p headless agent（在當前目錄動手）
      (let [permission (or (getenv-nonempty "WF_PERMISSION") "acceptEdits")
            p [(shquote claude) "-p" "--permission-mode" (shquote permission)]]
        (when (< 0 (length system))
          (table.insert p "--append-system-prompt") (table.insert p (shquote system)))
        (let [m (getenv-nonempty "WF_MODEL")]  (when m (table.insert p "--model")  (table.insert p (shquote m))))
        (let [e (getenv-nonempty "WF_EFFORT")] (when e (table.insert p "--effort") (table.insert p (shquote e))))
        (table.insert p "--") (table.insert p (shquote prompt))
        p)))

(local (_ _ code) (os.execute (table.concat parts " ")))
(os.exit (or code 0))
