{
  // cllm — 建議安裝的 VSCode 擴充（開這個資料夾時 VSCode 會提示安裝）。
  // 換機器（Windows ⇄ Linux）時最容易漏的就是這個——沒裝 cpptools 就沒有 cppdbg，
  // F5 直接跳「找不到偵錯類型」，看起來像設定壞了。
  "recommendations": [
    // 必裝：提供 launch.json 用的 cppdbg 除錯器 ＋ IntelliSense（讀 c_cpp_properties.json）。
    "ms-vscode.cpptools",
    // 選裝：側欄切 CMake preset／建置。不裝也能用 tasks.json（Ctrl+Shift+B）。
    "ms-vscode.cmake-tools"
  ]
}
