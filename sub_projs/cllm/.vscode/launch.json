{
  // cllm — C++ 除錯設定（gdb / MinGW）
  // 需先裝擴充套件：C/C++（發布者 Microsoft，ID: ms-vscode.cpptools）——提供 cppdbg 除錯器。
  //   （CMake Tools ms-vscode.cmake-tools 選裝：裝了能在側欄切 preset／建置，不裝也能用本設定。）
  //
  // F5 前會自動跑 preLaunchTask「cmake: build」建置。中斷點：demo.cpp 的 sum_to 迴圈、greet、main.cpp 的 run。
  //   傳統 header（非具名模組），符號名無模組修飾——除錯主控台 break sum_to 直接命中。
  // ⚠ 中文參數別用 args 傳（VSCode 傳給 gdb 的 argv 碼頁未必對）；要試中文改跑 build/try3.exe。
  // 以「File > Open Folder」開 try_3 這個資料夾（讓 ${workspaceFolder}=try_3）。
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug try3 (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/try3.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      // ★ miDebuggerPath 只放進「windows」平台區塊——Linux 上不給這欄，cppdbg 就用 PATH 上的 gdb。
      //   平台區塊（windows / linux / osx）VSCode 與 nvim-dap 都支援：會把該平台的鍵合併到頂層。
      //   這是「一份 launch.json 兩台機器共用」的關鍵——別把機器專屬路徑留在頂層。
      "windows": {
        "miDebuggerPath": "C:/dev/mingw64/bin/gdb.exe"
      },
      // preLaunchTask 指向 tasks.json 的「cmake: build」，該任務寫死 --preset mingw-debug（Windows 專用）。
      // 這是 VSCode 專屬機制，nvim 的 dap **不會**跑 preLaunchTask——用 nvim 除錯前要自己先
      // `cmake --build --preset linux-debug` 建置一次（見 README「編輯器整合」一節）。
      "preLaunchTask": "cmake: build",
      "setupCommands": [
        {
          "description": "為 gdb 啟用整齊列印（std::string/vector 等顯示成人看得懂的樣子）",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "字元集設 UTF-8（中文字串/變數在除錯視窗顯示正常）",
          "text": "set charset UTF-8",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
