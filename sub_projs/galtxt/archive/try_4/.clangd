# clangd 設定 — 編輯器中立（nvim/LazyVim、VSCode clangd 擴充皆讀這份）
#
# clangd 預設只往「當前檔案所在目錄」往上找 compile_commands.json，不會自動下探到 build/，
# 這裡明講去哪找（CMakeLists.txt 已開 CMAKE_EXPORT_COMPILE_COMMANDS，configure 後就在 build/ 底下）。
#
# ⚠ try_4 借編 ../try_3/src 的核心 .cpp：compile_commands.json 裡那幾條指令的路徑會指到 try_3，
#   clangd 照樣讀得懂（它認的是每條指令自帶的 -I／-isystem）。編輯 try_3/src 的檔仍看 try_3 自己的
#   .clangd／compile_commands（各自 build/），兩線不互相干擾。
CompileFlags:
  CompilationDatabase: build
  # CMake+Ninja 對 C++20 modules 依賴掃描（P1689）塞給 GCC 的旗標，clang 驅動器不認得，過濾掉。
  Remove:
    - -fmodules-ts
    - -fmodule-mapper=*
    - -fdeps-format=*
