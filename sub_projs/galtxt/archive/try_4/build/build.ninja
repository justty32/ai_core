build try4.exe: CXX_EXECUTABLE_LINKER__try4_Debug CMakeFiles/try4.dir/src/main.cpp.o CMakeFiles/try4.dir/src/bind_bridge.cpp.o CMakeFiles/try4.dir/src/lua_bind.cpp.o CMakeFiles/try4.dir/src/s7_bind.cpp.o CMakeFiles/try4.dir/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_3/src/http.cpp.o CMakeFiles/try4.dir/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_3/archived/llm.cpp.o CMakeFiles/try4.dir/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_3/archived/llm_tool.cpp.o CMakeFiles/try4.dir/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_3/archived/llm_media.cpp.o CMakeFiles/try4.dir/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_3/archived/llm_json.cpp.o | liblua_vendored.a libs7_vendored.a /usr/lib/libcurl.so /usr/lib/libcurl.so || liblua_vendored.a libs7_vendored.a
  CONFIG = Debug
  DEP_FILE = CMakeFiles/try4.dir/link.d
  FLAGS = -g
  LINK_FLAGS = -Wl,--dependency-file=CMakeFiles/try4.dir/link.d
  LINK_LIBRARIES = liblua_vendored.a  libs7_vendored.a  /usr/lib/libcurl.so  -ldl  -lm  /usr/lib/libcurl.so
  OBJECT_DIR = CMakeFiles/try4.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_FILE = try4.exe
  TARGET_PDB = try4.exe.dbg
  TARGET_SUPPORT_DIR = CMakeFiles/try4.dir


#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/lorkhan/repo/ai_core/sub_projs/galtxt/try_4/build && /usr/bin/ccmake -S/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_4 -B/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_4/build
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/lorkhan/repo/ai_core/sub_projs/galtxt/try_4/build && /usr/bin/cmake --regenerate-during-build -S/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_4 -B/home/lorkhan/repo/ai_core/sub_projs/galtxt/try_4/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

