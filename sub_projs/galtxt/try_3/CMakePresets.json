{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "C:/dev/mingw64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/dev/mingw64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/dev/mingw64/bin/mingw32-make.exe"
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "inherits": "mingw-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "mingw-debug", "configurePreset": "mingw-debug" },
    { "name": "mingw-release", "configurePreset": "mingw-release" }
  ]
}
