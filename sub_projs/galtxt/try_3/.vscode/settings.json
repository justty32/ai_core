{
  // galtxt try_3 — VSCode 工作區設定（C++ / CMake / UTF-8）
  // 除錯用 C/C++ 擴充（cppdbg，見 launch.json）；IntelliSense 見 c_cpp_properties.json。
  //
  // ⚠ 這裡**刻意不放** `C_Cpp.default.compilerPath` / `C_Cpp.default.intelliSenseMode`：
  //    那是**全域預設、不分平台**——原本寫死 `C:/dev/mingw64/bin/g++.exe` ＋ `windows-gcc-x64`，
  //    在 Linux 上就整個歪掉。編譯器與平台模式交給 c_cpp_properties.json 的 Win32／Linux
  //    兩個 configuration（VSCode 依 name 自動挑）。
  "cmake.useCMakePresets": "always", // CMake Tools 一律用 CMakePresets.json（若有裝）
  "files.encoding": "utf8", // 檔案存 UTF-8（中文註解/字串）
  "files.eol": "\n"
}
