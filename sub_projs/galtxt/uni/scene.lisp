;;;; scene.lisp — 河堤場景：八股→段→句式→填充→原子事實，全是同一種節點。
;;;; env 軸：:move（收束動詞）/:emo（情緒措辭）/:choice（選路）；母題由 :母題 帶入。

;;; 原子事實（真值域・葉）＋一條排斥（域邏輯只掃真值域）
(fact 母題-櫻花 "母題＝櫻花") (fact 地-河堤 "在河堤") (fact 地-天台 "在天台")
(defparameter *排斥* '((地-河堤 地-天台)))

;;; 填充（字面域・葉，帶選擇/邏輯）
(node 收束動詞 (? :move "來到" "走到" "繞回"))
(node 安定 (? :emo "沒關係的" "別怕" "我在啊"))
(node 會變項 (! (or (env :母題) "櫻花")))
(node 變化動詞 (! (if (equal (env :母題) "季節") "換了" "變了")))   ; 變項×動詞相配的邏輯內嵌
(node 不變的錨 (? :emo "我們還能一起走這條路" "我還會在這條路上等你" "我們改天去咖啡廳坐坐")) ; [2]非canon
(node 句尾 (? :emo "，不是嗎？" "。"))
(node 外界觀察 (! (format nil "~a也在變，大家卻都往前走了" (or (env :母題) "櫻花"))))
(node 怕輕描 (? :emo "會有點害怕呢" "就覺得有點站不住腳"))
(node 變樣句 (! (format nil "那些熟悉的~a，不知不覺就變了樣" (or (env :母題) "櫻花"))))
(node 語氣 (? :emo "嗯" "……啊")) (node 認可 (? :emo "你說得對" "說得也是呢"))

;;; 句式（字面域・內部，含說話者）
(node a1 "秋穗：「結果，還是" 收束動詞 "河堤了呢。」")
(node b1 "秋穗：「" 外界觀察 "。有時候……" 怕輕描 "。」")
(node c1 "主角：「害怕什麼？」")
(node c2 "秋穗：「怕自己停在原地。也怕" 變樣句 "。」")
(node d1 "主角：「" 安定 "。就算" 會變項 變化動詞 "，" 不變的錨 句尾 "」")
(node d2 "秋穗：「" 語氣 "……" 認可 "。謝謝你。」")
(node e1 "主角：「走吧，電車快來了。」")

;;; 旁白（葉）＋段（內部）
(node 旁A "（斜陽把影子拉長，兩側櫻堤落下最後的櫻花雨。）")
(node 旁D "（她微微一怔，轉過頭，落寞化作溫緩的笑意。）")
(node 旁E "（她輕輕點頭，與我並肩踏上歸途，最後的櫻花瓣落在她的髮梢。）")
(node 段A 旁A :nl a1) (node 段B b1) (node 段C c1 :nl c2)
(node 段D d1 :nl 旁D :nl d2) (node 段E e1 :nl 旁E)

;;; 八股整場（最粗）
(node 場 段A :nl 段B :nl 段C :nl 段D :nl 段E)

;;; 分支＝普通節點；懸空引用＝佔位工單
(node 分支A "主角：「去河鹿堂看看？」") (node 分支B "主角：「去陽溜亭？」")
(node 選擇肢 (? :choice 分支A 分支B))
(node 段E待展開 e1-尚未寫)
