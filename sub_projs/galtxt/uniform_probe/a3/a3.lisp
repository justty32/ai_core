;;;; a3.lisp — 統一節點 kernel（Common Lisp）。八股/段落/句式/填充物/原子事實＝同一種「節點」，粒度任意。
;;;; 每個節點都是一個 list：(ID :欄 值 …)，存於 *G*（唯一真源）。原子事實＝最細粒度（第0層），可帶邏輯。
;;;; 層數自然湧現：無引用＝第0層；有引用＝max(被引用層)+1。跑：sbcl --script a3.lisp（自帶 assert）。

;;; ════ kernel（節點容器＋層數＋接地＋一致性邏輯，全部就這一段）════════════════
(defvar *G* (make-hash-table :test 'eq))                     ; id → 節點（一張表即整張網）
(defmacro 節 (id &rest kv) `(progn (setf (gethash ',id *G*) ',(cons id kv)) ',id)) ; 造/註冊節點（kv＝literal data）
(defun g (id) (gethash id *G*))                              ; 取節點
(defun p (id k &optional d) (getf (cdr (g id)) k d))         ; 取欄位（欄不存回 d）
(defun 引 (id) (p id :引))                                    ; refs：此節點引用了哪些節點
(defun 層 (id) (let ((r (引 id))) (if r (1+ (reduce #'max (mapcar #'層 r))) 0))) ; 層數湧現
(defun 接地 (id) (let ((n (g id)))                            ; 沿 :引 下行必達存在的第0層＝非編造
                   (and n (every (lambda (r) (and (g r) (接地 r))) (引 id)))))
(defun 查 (pred) (let (r) (maphash (lambda (k v) (declare (ignore v))    ; match：回穩定序 id
                                     (when (funcall pred k) (push k r))) *G*)
                   (sort r #'string< :key #'symbol-name)))
(defun 細 (id) (let ((c (查 (lambda (x) (eq (p x :父) id))))) (if c (細 (first c)) id))) ; LOD 取最細
(defun 解 (id) (p (細 id) :值))                              ; resolve：讀時解析到最細 canon 值
(defun 誰引 (id) (查 (lambda (x) (member id (引 x)))))       ; backrefs：一致性傳播名單
(defun 真值? (id) (eq (p id :域 :真值) :真值))               ; 事實在真值域；句式/填充在字面域
;; 邏輯謂詞（只作用於真值域節點）───────────────────────────────────────────
(defun canon一致 (canon) (every (lambda (id) (notany (lambda (x) (member x canon)) (p id :斥))) canon)) ; 排斥邊不同入 canon
(defun 蘊含閉合 (canon) (every (lambda (id) (every (lambda (y) (member y canon)) (p id :蘊))) canon))   ; 蘊含之事實須同在
(defun 可改? (id) (not (p id :鎖)))                          ; canon 鎖：呈現過的事實不可改，只可再細化
(defun 細化合法? (child) (let ((par (p child :父)))          ; LOD 不變式：細化落在父約束內、不推翻父
                          (and par (g par) (eq (p par :型) :區間))))

;;; ════ 原子事實庫（第0層・:域 :真值）——《最後的櫻花雪》世界＋人物＋河堤場景 ════

;; ── 世界觀／年代／母題（氛圍級，被引用才細）──────────────────────────────
(節 世界/年代   :值 "90年代日本地方小鎮" :型 :區間)              ; 粗＝約束區間；細化在區間內取點（見下）
(節 世界/年代/1996 :值 "1996" :型 :具體 :父 世界/年代)          ; LOD 細化：只能落在父約束內
(節 世界/季節   :值 "四月・櫻花將盡")
(節 世界/花期落盡 :值 "花期落盡・最後一場櫻花雪")               ; R02＝母題閉合點
(節 母題/變動   :值 "變動：花落／粉轉綠／季節推移（全劇貫串母題）")
(節 母題/陪伴不變 :值 "變的是風景，一起走不變（主旨落點）")

;; ── 地（線性移動的常量）───────────────────────────────────────────────
(節 地/霞川     :值 "霞川・河川，夕陽下泛細碎金光")
(節 地/河堤     :值 "霞川河堤・碎石路")
(節 地/天台     :值 "舊校舍天台")
(節 地/杜坂     :值 "杜坂（下山坡道）")
(節 地/車站     :值 "老舊木造車站")
(節 地/商店街   :值 "鎮上商店街（遠景喧囂）")

;; ── 人（身分/個性為常量）─────────────────────────────────────────────
(節 人/秋穗     :值 "秋穗・女主角")
(節 秋穗/身分   :值 "同班同學・新生代表")
(節 秋穗/個性   :值 "逃避期待、愛沒人打擾的日常")
(節 秋穗/短髮   :值 "短髮（被風吹亂）")
(節 人/主角     :值 "主角・玩家視角")
(節 主角/個性   :值 "沉靜、留意細節（接得住不易察覺的情緒）")

;; ── 物（母題時鐘＋伏筆）──────────────────────────────────────────────
(節 物/舊書     :值 "泛黃舊書・封面河鹿堂梅花章" :型 :具體 :旗 :伏筆) ; A 線伏筆
(節 物/落櫻     :值 "最後的櫻花雨・飄水面打旋" :蘊 (世界/花期落盡))  ; 邏輯・蘊含：落櫻在→花期必落盡
(節 物/金河水   :值 "夕陽下泛金的河水")
(節 物/影子     :值 "被斜陽拉長的兩人影子（時間視覺化）")
(節 物/電車     :值 "將到站的電車（催促離場）")

;; ── 河堤場景・原子狀態（時／地／情緒）帶排斥邏輯 ──────────────────────────
(節 場/時傍晚   :值 "傍晚・斜陽" :斥 (場/時午後))              ; 同一拍時間唯一
(節 場/時午後   :值 "放學後・午後" :斥 (場/時傍晚))
(節 場/在河堤   :值 "本拍在河堤" :斥 (場/在天台))              ; 邏輯・排斥：同一拍不能兩地
(節 場/在天台   :值 "本拍在天台" :斥 (場/在河堤))
;; 秋穗情緒弧（自在→落寞→釋懷）：同一拍互斥；「落寞」是可 hides 的底（不易察覺＝反差前提）
(節 情/秋穗自在 :值 "自在放鬆" :斥 (情/秋穗落寞 情/秋穗釋懷))
(節 情/秋穗落寞 :值 "不易察覺的落寞（怕停滯・怕熟悉風景變樣）"
   :斥 (情/秋穗自在 情/秋穗釋懷) :持 秋穗 :態 :hides)          ; 知識視圖：秋穗藏、待洩的底
(節 情/秋穗釋懷 :值 "落寞消散・溫緩笑意" :斥 (情/秋穗自在 情/秋穗落寞)
   :蘊 (好感/秋穗對主角+1))                                   ; 邏輯・蘊含：釋懷則好感躍升（R12）
(節 好感/秋穗對主角+1 :值 "秋穗對主角好感 +1（R12 正向躍升）")

;;; ════ 中粒度節點——引用原子事實往上長（層數＝被引用最大層+1）════════════════
;; 第1層：關係（引兩個第0層人物）
(節 關係/並肩   :值 "並肩・影子重疊（親近）" :引 (人/秋穗 人/主角 物/影子))
(節 關係/喜歡   :值 "秋穗↔主角情感連結被言明（R11「我們一起走」）" :引 (人/秋穗 人/主角))
;; 第1層：場景狀態（引時/地/人/物/情緒一束原子事實）
(節 場景/河堤談心 :值 "河堤・傍晚・談心情感高點"
   :引 (地/河堤 場/時傍晚 人/秋穗 人/主角 物/落櫻 情/秋穗落寞))
;; 第2層：戲劇結構（引一個第1層關係＋一個第0層母題）→ 層自動＝2，越上越敘事
(節 戲劇/情感payoff :值 "R11：以『陪伴不變』翻轉『怕變』＝主旨落點"
   :引 (母題/變動 母題/陪伴不變 關係/並肩))

;;; ════ 同構對照組——句式/填充物也是節點，但活在字面域（:域 :字面）════════════
;; 填充物節點：值＝措辭候選（無真假、canon/排斥/蘊含對它無意義）
(節 填/收束地   :域 :字面 :型 :候選 :值 ("河堤" "河邊" "這裡"))
(節 填/安定句   :域 :字面 :型 :候選 :值 ("沒關係的" "別怕" "我在啊"))
;; 句式節點：引填充物節點組模板（層數機制照用：引第0層字面節點→第1層句式）
(節 句/d1安定托底 :域 :字面 :型 :模板 :值 "{安定句}。就算風景變了，還能一起走"
   :引 (填/安定句 填/收束地))

;;; ════════ 自帶 assert（事實可查／層數／接地／排斥／蘊含／canon鎖／LOD／域分離）════════
(defun 原子事實 () (查 (lambda (x) (and (真值? x) (= (層 x) 0))))) ; 第0層真值域＝原子事實

(let ((*standard-output* *standard-output*))
  ;; ① 事實可查 + resolve（含 LOD 讀到最細 canon 值）
  (assert (string= (解 '世界/季節) "四月・櫻花將盡"))
  (assert (string= (解 '世界/年代) "1996"))                   ; resolve 穿透 LOD 取最細，非粗值"90年代"
  (assert (member '情/秋穗落寞 (查 (lambda (x) (eq (p x :態) :hides))))) ; 「秋穗可洩的底」match

  ;; ② 層數湧現：原子=0、關係=1、場景=1、戲劇payoff=2
  (assert (= 0 (層 '人/秋穗)))
  (assert (= 1 (層 '關係/並肩)))
  (assert (= 1 (層 '場景/河堤談心)))
  (assert (= 2 (層 '戲劇/情感payoff)))                        ; 引第1層關係→自動升到第2層
  (assert (= 1 (層 '句/d1安定托底)))                          ; 字面域同享層數機制（同構於容器）

  ;; ③ 接地不變式：真實節點皆接地；懸空引用＝編造，機械可查
  (assert (every #'接地 (原子事實)))
  (assert (接地 '戲劇/情感payoff))
  (節 編造/懸空 :值 "引用不存在的事實" :引 (根本沒這條))
  (assert (not (接地 '編造/懸空)))                            ; 懸空連結→接地失敗
  (remhash '編造/懸空 *G*)

  ;; ④ 排斥邏輯：排斥邊兩端不得同入 canon
  (assert (canon一致 '(場/在河堤 情/秋穗落寞 場/時傍晚)))     ; 相容的一束→通過
  (assert (not (canon一致 '(場/在河堤 場/在天台))))           ; 同拍兩地→矛盾
  (assert (not (canon一致 '(情/秋穗自在 情/秋穗落寞))))       ; 同拍兩情緒→矛盾

  ;; ⑤ 蘊含邏輯：入 canon 的事實，其蘊含之事實須同在（閉合）
  (assert (not (蘊含閉合 '(物/落櫻))))                       ; 落櫻在、花期落盡缺→未閉合
  (assert (蘊含閉合 '(物/落櫻 世界/花期落盡)))               ; 補上→閉合
  (assert (蘊含閉合 '(情/秋穗釋懷 好感/秋穗對主角+1)))       ; 釋懷⇒好感+1

  ;; ⑥ canon 鎖：呈現過的事實不可改，只可再細化
  (節 世界/年代 :值 "90年代日本地方小鎮" :型 :區間 :鎖 t)      ; 標記已呈現＝鎖
  (assert (not (可改? '世界/年代)))
  (assert (可改? '世界/年代/1996))                            ; 未呈現的細化子仍可改

  ;; ⑦ LOD 不變式：細化必須落在父的區間約束內
  (assert (細化合法? '世界/年代/1996))                        ; 父是區間→合法
  (assert (not (細化合法? '人/秋穗)))                         ; 無父→不是合法細化

  ;; ⑧ backrefs：反向連結＝改動傳播名單
  (assert (member '關係/並肩 (誰引 '人/秋穗)))
  (assert (member '戲劇/情感payoff (誰引 '關係/並肩)))

  ;; ⑨ 域分離：一致性邏輯只作用真值域；字面域節點不參與（但共享容器/層/引用）
  (assert (真值? '情/秋穗落寞))
  (assert (not (真值? '填/收束地)))
  (assert (equal (p '填/收束地 :值) '("河堤" "河邊" "這裡")))  ; 字面節點值＝措辭候選，非命題

  (format t "全部 assert 通過。~%")
  (format t "原子事實（第0層・真值域）共 ~a 條。~%" (length (原子事實)))
  (format t "帶邏輯的原子事實：蘊含 ~a 條、排斥 ~a 條、canon鎖 ~a 條。~%"
          (length (查 (lambda (x) (and (真值? x) (p x :蘊)))))
          (length (查 (lambda (x) (and (真值? x) (p x :斥)))))
          (length (查 (lambda (x) (p x :鎖)))))
  (format t "全庫節點 ~a 個；最高層＝第 ~a 層（~a）。~%"
          (hash-table-count *G*) (層 '戲劇/情感payoff) '戲劇/情感payoff))
