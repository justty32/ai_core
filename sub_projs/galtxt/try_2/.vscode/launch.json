{
  // galtxt try_2 — Lua 除錯設定
  // 需先裝擴充套件：Local Lua Debugger（發布者 tomblind，ID: tomblind.local-lua-debugger-vscode）
  //   —— 純 Lua 除錯器、不需原生模組。可在 src/cli.lua / src/llm.lua / src/json.lua 下中斷點。
  //
  // ⚠ 直譯器要用標準 build/lua.exe，不能用 host.exe：
  //    host.exe 只吃「<腳本> 參數」、不支援除錯器要注入的 -e 引導，會起不來。
  //    lua.exe 是標準直譯器（內建 arg 表），我們腳本原封不動能跑。先 ./build.sh luaexe 產生它。
  // 以「File > Open Folder」開 try_2 這個資料夾（讓 ${workspaceFolder}=try_2）。
  "version": "0.2.0",
  "configurations": [
    {
      // 擺第一個：picker（nvim-dap）與 VSCode 的下拉選單都預設選第一項，而「跑當前檔案」是最常按的。
      // ⚠ 只適合**可獨立執行**的檔案（test/*.lua、examples/*.lua、src/cli.lua）。拿它跑**模組**
      //    （src/llm.lua、src/json.lua…）會白等：執行模組只是定義函式然後 return M，函式體一行都不跑，
      //    你下在 M.llm_entry 裡的中斷點雖回報 verified=true，卻永遠等不到。要停在模組內部，
      //    改選下面那些有主程式的設定（Debug cli／Debug test／demo_*），它們會真的呼叫進去。
      "name": "Debug 目前開啟的 .lua 檔",
      "type": "lua-local",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": { "lua": "${workspaceFolder}/build/lua.exe", "file": "${relativeFile}" }
    },
    {
      // ⚠ 僅 Windows：別用 --prompt 傳中文（cmd 的 argv 是 950 碼頁會壞），走 --infile（讀檔是原始 UTF-8）。
      //    Linux/macOS 的 argv 本來就是 UTF-8，--prompt 直接傳中文沒問題（見下一組設定）。
      "name": "Debug cli（離線假回應）",
      "type": "lua-local",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": { "lua": "${workspaceFolder}/build/lua.exe", "file": "src/cli.lua" },
      "args": [
        "--base-url", "file://${workspaceFolder}/test/fixtures/fake",
        "--infile", "test/sample_prompt.txt",
        "--temp", "0.7"
      ]
    },
    {
      "name": "Debug cli（真後端，需先開 LM Studio）",
      "type": "lua-local",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": { "lua": "${workspaceFolder}/build/lua.exe", "file": "src/cli.lua" },
      "args": ["--prompt", "你好", "--temp", "0.7"]
    },
    {
      "name": "Debug test（離線 E2E）",
      "type": "lua-local",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": { "lua": "${workspaceFolder}/build/lua.exe", "file": "test/test.lua" }
    },
    {
      "name": "Debug demo_lua（Lua 格式輸出）",
      "type": "lua-local",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": { "lua": "${workspaceFolder}/build/lua.exe", "file": "examples/demo_lua.lua" }
    },
    {
      "name": "Debug demo_stream（串流 callback）",
      "type": "lua-local",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": { "lua": "${workspaceFolder}/build/lua.exe", "file": "examples/demo_stream.lua" }
    }
  ]
}
