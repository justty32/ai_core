{
  // ── Alive（Common Lisp 擴充 rheller.alive）──
  // startCommand 是「完整啟動指令」，Alive 逐字執行、再讀 stdout 抓 server port。
  // 必須自己載 alive-lsp 並啟 server，不能只給 sbcl 執行檔。
  // 序列：require asdf → 載 quicklisp（讓 asdf 找得到 alive-lsp 的相依 usocket 等）
  //       → 載 alive-lsp（靠 Alive 設的 CL_SOURCE_REGISTRY 找到）→ 啟 server（印 port）。
  "alive.lsp.startCommand": [
    "C:\\Program Files\\Steel Bank Common Lisp\\sbcl.exe",
    "--noinform",
    "--eval", "(require :asdf)",
    "--eval", "(let ((s (merge-pathnames \"quicklisp/setup.lisp\" (user-homedir-pathname)))) (when (probe-file s) (load s)))",
    "--eval", "(asdf:load-system :alive-lsp)",
    "--eval", "(alive/server:start)"
  ],

  // ── 開發手感 ──
  // 注意：*.lisp 不要硬綁成 "lisp"！Alive 註冊的語言 id 是 "commonlisp"，
  // 綁錯會讓 Alive 的文法與 LSP 都掛不上（＝沒高亮、LSP 不 attach）。讓 Alive 的預設關聯生效即可。
  "editor.formatOnType": true,
  "[commonlisp]": {
    "editor.wordSeparators": "()[]{}\",'`;#|",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  }
}
