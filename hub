#!/usr/bin/env python3
"""
hub — one-shot process index tool

Usage:
  hub --build-list <dir> [--output <file>]      scan dir, call --metadata on each, write list.json
  hub --search-func <query> [--list <file>]     read list.json, return matching processes
  hub --validate <process_path>                 check that a process meets the --metadata contract
                                                (and run examples if metadata declares any)
  hub --gen-agents-md [--list <file>] [--output <file>]
                                                emit a markdown entry doc for AI agents
  hub --gen-functions-md [--list <file>] [--output <file>]
                                                emit a markdown listing of every process
  hub --export <format> [--list <file>] [--output <file>]
                                                emit process catalog as tool schemas
                                                formats: openai-tools | anthropic-tools

Global flags:
  --json-errors                                 emit stderr errors as single-line JSON
                                                ({"type", "message", "hint", "retriable"})

Process contract (see SYSTEM_DESIGN.md):
  ./process --metadata        prints a single-line JSON object to stdout, exits 0
  ./process [<arg> | stdin]   executes; success → stdout + exit 0;
                              failure → stderr message + non-zero exit
"""
import sys
import json
import subprocess
from pathlib import Path


DEFAULT_LIST = Path("list.json")
METADATA_TIMEOUT = 10
EXAMPLE_TIMEOUT = 15

REQUIRED_FIELDS = ("name", "description")
OPTIONAL_FIELDS = ("version", "tags", "input", "output", "examples", "io")

# Allowed values inside the structured `io` field
_IO_INPUT = {"stdin", "file", "args", "none"}
_IO_OUTPUT = {"stdout", "file", "none"}
_IO_FORMAT = {"text", "json", "binary"}


def _io_warnings(io: dict) -> list[str]:
    """Return list of human-readable issues with an `io` block (empty = clean)."""
    warns = []
    if not isinstance(io, dict):
        return ["io must be a JSON object"]
    inp = io.get("input")
    out = io.get("output")
    if inp is not None and inp not in _IO_INPUT:
        warns.append(f"io.input '{inp}' not in {sorted(_IO_INPUT)}")
    if out is not None and out not in _IO_OUTPUT:
        warns.append(f"io.output '{out}' not in {sorted(_IO_OUTPUT)}")
    fmt = io.get("format")
    if isinstance(fmt, dict):
        for k in ("input", "output"):
            v = fmt.get(k)
            if v is not None and v not in _IO_FORMAT:
                warns.append(f"io.format.{k} '{v}' not in {sorted(_IO_FORMAT)}")
    elif fmt is not None:
        warns.append("io.format must be a JSON object (e.g., {\"input\": \"text\"})")
    return warns

_JSON_ERRORS = False


def _err(error_type: str, message: str, hint: str = "", retriable: bool = False):
    """Emit one error to stderr. JSON mode → single-line JSON object; else human text."""
    if _JSON_ERRORS:
        obj = {"type": error_type, "message": message, "hint": hint, "retriable": retriable}
        print(json.dumps(obj, ensure_ascii=False), file=sys.stderr)
    else:
        line = f"{error_type}: {message}"
        if hint:
            line += f" (hint: {hint})"
        print(line, file=sys.stderr)


def _run_metadata(path: Path) -> tuple[dict | None, str]:
    """Return (metadata, error_message). metadata is None on hard failure (no JSON object)."""
    try:
        r = subprocess.run(
            [sys.executable, str(path), "--metadata"],
            capture_output=True, text=True, timeout=METADATA_TIMEOUT,
        )
    except subprocess.TimeoutExpired:
        return None, f"timeout after {METADATA_TIMEOUT}s"
    except OSError as e:
        return None, f"exec failed: {e}"

    if r.returncode != 0:
        return None, f"exit {r.returncode}; stderr: {r.stderr.strip()[:200]}"

    try:
        meta = json.loads(r.stdout.strip())
    except json.JSONDecodeError as e:
        return None, f"invalid JSON: {e}"

    if not isinstance(meta, dict):
        return None, "metadata must be a JSON object"

    return meta, ""


def _classify(meta: dict | None, err: str, path: Path) -> dict:
    """Build a list.json entry from raw metadata + error. Always returns an entry.

    _status:
      ok      — required fields present, no warning
      partial — metadata parsed but some required fields missing
      absent  — --metadata failed entirely (exit non-0, bad JSON, etc.)
    """
    if meta is None:
        return {
            "name": path.stem,
            "description": "(no metadata)",
            "path": str(path.resolve()),
            "_status": "absent",
            "_warning": err,
        }

    missing = [f for f in REQUIRED_FIELDS if f not in meta]
    entry = dict(meta)
    entry["path"] = str(path.resolve())
    if missing:
        entry.setdefault("name", path.stem)
        entry.setdefault("description", "(no description)")
        entry["_status"] = "partial"
        entry["_warning"] = f"missing required fields: {missing}"
    else:
        entry["_status"] = "ok"
    return entry


def build_list(processes_dir: str, output: Path = DEFAULT_LIST):
    processes = Path(processes_dir)
    if not processes.is_dir():
        _err("InvalidPath", f"{processes_dir} is not a directory")
        sys.exit(1)

    results = []
    degraded = []
    for f in sorted(processes.iterdir()):
        if not f.is_file():
            continue
        if f.name.startswith(".") or f.name.startswith("_"):
            continue

        meta, err = _run_metadata(f)
        entry = _classify(meta, err, f)
        results.append(entry)
        if entry["_status"] != "ok":
            degraded.append((f.name, entry["_status"], entry["_warning"]))

    tmp = output.with_suffix(".tmp")
    tmp.write_text(json.dumps(results, ensure_ascii=False, indent=2))
    tmp.rename(output)

    ok_count = sum(1 for e in results if e["_status"] == "ok")
    print(f"Registered {len(results)} processes ({ok_count} ok, {len(degraded)} degraded) → {output}")
    for name, status, warning in degraded:
        _err(f"Metadata{status.capitalize()}", f"{name}: {warning}",
             hint="run `hub --validate <path>` for details", retriable=False)


def search_func(query: str, list_file: Path = DEFAULT_LIST):
    if not query:
        _err("InvalidQuery", "--search-func requires a non-empty query")
        sys.exit(2)

    if not list_file.exists():
        _err("ListNotFound", f"{list_file} not found",
             hint="run --build-list first")
        sys.exit(2)

    entries = json.loads(list_file.read_text())
    q = query.lower()
    matches = []
    for e in entries:
        if e.get("_status") == "absent":
            continue  # nothing useful to match against
        haystack = " ".join([
            e.get("name", ""),
            e.get("description", ""),
            " ".join(e.get("tags", [])),
        ]).lower()
        if q in haystack:
            matches.append(e)

    print(json.dumps(matches, ensure_ascii=False, indent=2))


def _run_example(path: Path, input_text: str) -> tuple[str, str, int]:
    """Run process with input_text on stdin. Returns (stdout, stderr, returncode)."""
    try:
        r = subprocess.run(
            [sys.executable, str(path)],
            input=input_text, capture_output=True, text=True,
            timeout=EXAMPLE_TIMEOUT,
        )
        return r.stdout, r.stderr, r.returncode
    except subprocess.TimeoutExpired:
        return "", f"timeout after {EXAMPLE_TIMEOUT}s", -1


def _check_examples(path: Path, examples: list) -> list[str]:
    """Run each example. Return list of failure strings (empty if all pass)."""
    failures = []
    for i, ex in enumerate(examples):
        if not isinstance(ex, dict) or "input" not in ex or "output" not in ex:
            failures.append(f"example[{i}]: must be object with 'input' and 'output'")
            continue
        stdout, stderr, rc = _run_example(path, ex["input"])
        if rc != 0:
            failures.append(f"example[{i}]: exit {rc}; stderr: {stderr.strip()[:120]}")
            continue
        actual = stdout.rstrip("\n")
        expected = ex["output"].rstrip("\n")
        if actual != expected:
            failures.append(
                f"example[{i}]: output mismatch\n"
                f"    expected: {expected!r}\n"
                f"    actual:   {actual!r}"
            )
    return failures


def validate(process_path: str):
    p = Path(process_path)
    if not p.is_file():
        _err("NotAFile", f"{process_path} is not a file")
        sys.exit(2)
    if not (p.stat().st_mode & 0o111):
        _err("NotExecutable", f"{process_path} is not executable",
             hint="chmod +x")
        sys.exit(2)

    meta, err = _run_metadata(p)
    if meta is None:
        _err("MetadataAbsent", f"--metadata: {err}")
        sys.exit(1)

    missing = [f for f in REQUIRED_FIELDS if f not in meta]
    if missing:
        _err("MetadataPartial", f"missing required fields: {missing}")
        sys.exit(1)

    examples = meta.get("examples", [])
    if examples:
        if not isinstance(examples, list):
            _err("InvalidExamples", "metadata.examples must be a list")
            sys.exit(1)
        failures = _check_examples(p, examples)
        if failures:
            _err("ExampleFailed", f"{len(failures)}/{len(examples)} example(s) failed",
                 hint="see stderr below")
            for line in failures:
                print(f"  - {line}", file=sys.stderr)
            sys.exit(1)
        print(f"OK: {meta['name']} — {meta['description']} "
              f"({len(examples)} example(s) passed)")
    else:
        print(f"OK: {meta['name']} — {meta['description']} (no examples)")

    extras = [k for k in meta if k not in REQUIRED_FIELDS + OPTIONAL_FIELDS]
    if extras:
        _err("UnknownFields", f"unknown metadata fields: {extras}",
             hint="not an error; just FYI for AI authors")

    if "io" in meta:
        for w in _io_warnings(meta["io"]):
            _err("InvalidIo", w, hint="see README §「結構化 io 欄位」")


def _load_list(list_file: Path) -> list:
    if not list_file.exists():
        _err("ListNotFound", f"{list_file} not found", hint="run --build-list first")
        sys.exit(2)
    return json.loads(list_file.read_text())


def _write_or_print(text: str, output: str | None):
    if output:
        out = Path(output)
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(text)
        print(f"Wrote {out}")
    else:
        sys.stdout.write(text)


def gen_agents_md(list_file: Path, output: str | None = None):
    """Generate AGENTS.md — a self-contained entry doc for AI agents."""
    entries = _load_list(list_file)
    ok = [e for e in entries if e.get("_status") == "ok"]

    lines = []
    lines.append("# ai_core — Agent Guide\n")
    lines.append("> Auto-generated by `hub --gen-agents-md`. Do not hand-edit.\n")
    lines.append("\n## 系統概念\n")
    lines.append(
        "\n每個能力都是一個 **process**（可執行檔），遵守 `--metadata` 約定。\n"
        "Hub 是一次性索引工具，不是 server。\n"
    )
    lines.append("\n## 你能做什麼\n")
    lines.append(
        "\n- 找已有 process：`hub --search-func \"<keyword>\"`\n"
        "- 看單一 process 的 metadata：`./processes/<name>.py --metadata`\n"
        "- 跑 process：`echo \"input\" | ./processes/<name>.py` 或 `./processes/<name>.py \"input\"`\n"
        "- 新增 process：見 README §「AI 寫 process 的標準流程」六步\n"
    )
    lines.append("\n## Process 約定\n")
    lines.append(
        "\n- `--metadata` 旗標印一行 JSON，含必填 `name`、`description`，選填 `version`、`tags`、`input`、`output`、`examples`。\n"
        "- 一般執行：CLI arg 或 stdin 二擇一接受輸入；成功寫 stdout exit 0；失敗寫 stderr non-zero exit。\n"
        "- `examples` 內每個 `{input, output}` 都會被 `hub --validate` 自動執行比對，當作回歸測試。\n"
    )
    lines.append("\n## 目前可用 process\n")
    lines.append(f"\n共 {len(ok)} 個（degraded {len(entries) - len(ok)} 個已隱藏）。\n")
    by_tag: dict[str, list] = {}
    for e in ok:
        tags = e.get("tags") or ["(no tag)"]
        for t in tags:
            by_tag.setdefault(t, []).append(e)

    for tag in sorted(by_tag):
        lines.append(f"\n### `{tag}`\n\n")
        for e in sorted(by_tag[tag], key=lambda x: x["name"]):
            lines.append(f"- **{e['name']}** — {e.get('description', '')}\n")

    lines.append("\n## 進入專案後的建議流程\n")
    lines.append(
        "\n1. 跑 `hub --search-func \"<關鍵字>\"` 看有什麼可用；不確定時直接讀 `auto/FUNCTIONS.md`\n"
        "2. 找到候選 process 後跑一次 `--metadata` 確認 io 約定\n"
        "3. 編排：用 `processes/chain.py` 串連，或用 `processes/planner.py` 從自然語言任務產出計劃\n"
        "4. 沒有合適的 process 時：跟使用者確認後，照六步流程新增一個\n"
    )
    _write_or_print("".join(lines), output)


def gen_functions_md(list_file: Path, output: str | None = None):
    """Generate FUNCTIONS.md — a full reference of every process."""
    entries = _load_list(list_file)
    lines = []
    lines.append("# ai_core — Functions\n")
    lines.append("> Auto-generated by `hub --gen-functions-md`. Do not hand-edit.\n")
    lines.append(f"\n{len(entries)} processes total.\n")

    for e in sorted(entries, key=lambda x: x.get("name", "")):
        status = e.get("_status", "ok")
        badge = "" if status == "ok" else f" `[{status}]`"
        lines.append(f"\n## `{e.get('name', '?')}`{badge}\n\n")
        lines.append(f"{e.get('description', '(no description)')}\n\n")
        if e.get("tags"):
            lines.append(f"- **tags**: {', '.join(e['tags'])}\n")
        if e.get("version"):
            lines.append(f"- **version**: {e['version']}\n")
        if e.get("io"):
            io = e["io"]
            fmt = io.get("format") or {}
            in_fmt = fmt.get("input", "text") if isinstance(fmt, dict) else "text"
            out_fmt = fmt.get("output", "text") if isinstance(fmt, dict) else "text"
            lines.append(
                f"- **io**: {io.get('input', '?')} ({in_fmt}) → "
                f"{io.get('output', '?')} ({out_fmt})\n"
            )
        elif e.get("input") or e.get("output"):
            lines.append(f"- **io**: `{e.get('input', '?')}` → `{e.get('output', '?')}`\n")
        if e.get("path"):
            rel = e["path"]
            lines.append(f"- **path**: `{rel}`\n")
        if e.get("_warning"):
            lines.append(f"- **warning**: {e['_warning']}\n")
        examples = e.get("examples") or []
        if examples:
            lines.append("\n**Examples**:\n\n")
            for ex in examples:
                inp = ex.get("input", "")
                outp = ex.get("output", "")
                lines.append(f"```\n$ echo {inp!r} | <process>\n{outp}\n```\n\n")

    _write_or_print("".join(lines), output)


def _input_schema(entry: dict) -> dict:
    """JSON schema for one process's input. Uniform: single string `input`.

    If structured `io.format.input` declares `json` or `binary`, callers can be
    hinted via description; tool-calling APIs only accept JSON-stringifiable
    types, so we still expose `input: string` and let the process parse.
    """
    desc = entry.get("input") or "Input text passed to the process via stdin or argv[1]"
    io = entry.get("io") or {}
    fmt = (io.get("format") or {}) if isinstance(io.get("format"), dict) else {}
    in_fmt = fmt.get("input")
    if in_fmt == "json":
        desc += " (must be a JSON-encoded string)"
    elif in_fmt == "binary":
        desc += " (binary payload, base64-encode before passing)"
    return {
        "type": "object",
        "properties": {
            "input": {"type": "string", "description": desc},
        },
        "required": ["input"],
    }


def _export_openai_tools(entries: list) -> str:
    tools = []
    for e in entries:
        if e.get("_status") != "ok":
            continue
        tools.append({
            "type": "function",
            "function": {
                "name": e["name"],
                "description": e.get("description", ""),
                "parameters": _input_schema(e),
            },
        })
    return json.dumps(tools, ensure_ascii=False, indent=2) + "\n"


def _export_anthropic_tools(entries: list) -> str:
    tools = []
    for e in entries:
        if e.get("_status") != "ok":
            continue
        tools.append({
            "name": e["name"],
            "description": e.get("description", ""),
            "input_schema": _input_schema(e),
        })
    return json.dumps(tools, ensure_ascii=False, indent=2) + "\n"


_EXPORT_FORMATS = {
    "openai-tools": _export_openai_tools,
    "anthropic-tools": _export_anthropic_tools,
}


def export(format_name: str, list_file: Path, output: str | None = None):
    if format_name not in _EXPORT_FORMATS:
        _err("UnknownFormat", f"--export format must be one of {sorted(_EXPORT_FORMATS)}",
             hint=f"got '{format_name}'")
        sys.exit(2)
    entries = _load_list(list_file)
    text = _EXPORT_FORMATS[format_name](entries)
    _write_or_print(text, output)


def _arg_after(args, flag, default=None):
    if flag not in args:
        return default
    i = args.index(flag) + 1
    if i >= len(args) or args[i].startswith("--"):
        return default
    return args[i]


def main():
    global _JSON_ERRORS
    args = sys.argv[1:]

    if "--json-errors" in args:
        _JSON_ERRORS = True

    if "--build-list" in args:
        d = _arg_after(args, "--build-list", "./processes")
        out = Path(_arg_after(args, "--output", str(DEFAULT_LIST)))
        build_list(d, out)

    elif "--search-func" in args:
        q = _arg_after(args, "--search-func", "")
        lf = Path(_arg_after(args, "--list", str(DEFAULT_LIST)))
        search_func(q, lf)

    elif "--validate" in args:
        p = _arg_after(args, "--validate")
        if not p:
            _err("MissingArg", "--validate requires a process path")
            sys.exit(2)
        validate(p)

    elif "--gen-agents-md" in args:
        lf = Path(_arg_after(args, "--list", str(DEFAULT_LIST)))
        out = _arg_after(args, "--output", None)
        gen_agents_md(lf, out)

    elif "--gen-functions-md" in args:
        lf = Path(_arg_after(args, "--list", str(DEFAULT_LIST)))
        out = _arg_after(args, "--output", None)
        gen_functions_md(lf, out)

    elif "--export" in args:
        fmt = _arg_after(args, "--export")
        if not fmt:
            _err("MissingArg", "--export requires a format name",
                 hint=f"one of {sorted(_EXPORT_FORMATS)}")
            sys.exit(2)
        lf = Path(_arg_after(args, "--list", str(DEFAULT_LIST)))
        out = _arg_after(args, "--output", None)
        export(fmt, lf, out)

    else:
        print(__doc__.strip())
        sys.exit(1)


if __name__ == "__main__":
    main()
