#!/usr/bin/env python3
"""
hub — one-shot process index tool

Usage:
  hub --build-list <dir> [--output <file>]   scan dir, call --metadata on each, write list.json
  hub --search-func <query> [--list <file>]  read list.json, return matching processes
"""
import sys
import json
import subprocess
from pathlib import Path


DEFAULT_LIST = Path("list.json")


def build_list(processes_dir: str, output: Path = DEFAULT_LIST):
    processes = Path(processes_dir)
    if not processes.is_dir():
        print(f"Error: {processes_dir} is not a directory", file=sys.stderr)
        sys.exit(1)

    results = []
    for f in sorted(processes.iterdir()):
        if not f.is_file():
            continue
        try:
            r = subprocess.run(
                [str(f), "--metadata"],
                capture_output=True, text=True, timeout=10
            )
            if r.returncode != 0:
                continue
            meta = json.loads(r.stdout.strip())
            meta["path"] = str(f.resolve())
            results.append(meta)
        except (subprocess.TimeoutExpired, json.JSONDecodeError, PermissionError):
            pass

    # atomic write
    tmp = output.with_suffix(".tmp")
    tmp.write_text(json.dumps(results, ensure_ascii=False, indent=2))
    tmp.rename(output)
    print(f"Registered {len(results)} processes → {output}")


def search_func(query: str, list_file: Path = DEFAULT_LIST):
    if not list_file.exists():
        print("[]")
        return

    entries = json.loads(list_file.read_text())
    q = query.lower()
    matches = []
    for e in entries:
        name = e.get("name", "").lower()
        desc = e.get("description", "").lower()
        tags = [t.lower() for t in e.get("tags", [])]
        if q in name or q in desc or any(q in t for t in tags):
            matches.append(e)

    print(json.dumps(matches, ensure_ascii=False, indent=2))


def main():
    args = sys.argv[1:]

    if "--build-list" in args:
        idx = args.index("--build-list")
        d = args[idx + 1] if idx + 1 < len(args) and not args[idx + 1].startswith("--") else "./processes"
        out = Path(args[args.index("--output") + 1]) if "--output" in args else DEFAULT_LIST
        build_list(d, out)

    elif "--search-func" in args:
        idx = args.index("--search-func")
        q = args[idx + 1] if idx + 1 < len(args) and not args[idx + 1].startswith("--") else ""
        lf = Path(args[args.index("--list") + 1]) if "--list" in args else DEFAULT_LIST
        search_func(q, lf)

    else:
        print(__doc__.strip())
        sys.exit(1)


if __name__ == "__main__":
    main()
